{
  "title": "DevOps Portfolio — App Metrics",
  "uid": "devops-portfolio",
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Requests por segundo",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(app_requests_total[1m]))",
        "legendFormat": "req/s"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": {
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 10},
          {"color": "red", "value": 50}
        ]}
      }}
    },
    {
      "id": 2, "type": "stat", "title": "Latencia promedio (p50)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.50, rate(app_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p50"
      }],
      "fieldConfig": { "defaults": {
        "unit": "s",
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 0.5},
          {"color": "red", "value": 1}
        ]}
      }}
    },
    {
      "id": 3, "type": "stat", "title": "Total notas en DB",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "app_notes_total", "legendFormat": "notas" }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 4, "type": "stat", "title": "Tasa de errores 5xx",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(app_requests_total{status=~'5..'}[5m])) or vector(0)",
        "legendFormat": "errores/s"
      }],
      "fieldConfig": { "defaults": {
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          {"color": "green", "value": null},
          {"color": "red", "value": 0.1}
        ]}
      }}
    },
    {
      "id": 5, "type": "timeseries", "title": "Requests por endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by(endpoint, method)(rate(app_requests_total[1m]))",
        "legendFormat": "{{method}} {{endpoint}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Latencia por percentil",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(app_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(app_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(app_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "CPU del host (%)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
        "legendFormat": "CPU {{instance}}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Memoria del host",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Usado"
        },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Disponible" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
